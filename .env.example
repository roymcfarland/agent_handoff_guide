# Repository root — Vite loads env from here (vite.config.ts envDir).

# Public site URL (no trailing slash). Used at build time for canonical, Open Graph, Twitter Card, and JSON-LD absolute URLs. Example: https://your-domain.vercel.app
# VITE_SITE_URL=

# Optional: Umami (or compatible) analytics — both must be set to enable the script in client/src/main.tsx.
# Example endpoint: https://analytics.example.com  (no trailing slash)
# VITE_ANALYTICS_ENDPOINT=
# VITE_ANALYTICS_WEBSITE_ID=

# Production Express server (pnpm start) — default 3000
# PORT=3000

# Optional: extra comma-separated hosts allowed by the Vite dev server
# VITE_DEV_ALLOWED_HOSTS=

# Optional: Vite dev-only storage proxy (/dev-storage in vite.config.ts)
# BUILT_IN_FORGE_API_URL=
# BUILT_IN_FORGE_API_KEY=
