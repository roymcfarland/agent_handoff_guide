{
  "name": "agent_handoff_guide",
  "version": "1.0.0",
  "description": "Source for the Worksmith Labs Agent Handoff Framework reference site (worksmithlabs.com): document schema, prompt library, and failure-mode guardrails for shipping software with AI coding agents.",
  "type": "module",
  "license": "MIT",
  "author": "Roy McFarland",
  "repository": {
    "type": "git",
    "url": "https://github.com/roymcfarland/agent_handoff_guide.git"
  },
  "bugs": {
    "url": "https://github.com/roymcfarland/agent_handoff_guide/issues"
  },
  "homepage": "https://worksmithlabs.com",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "preview": "vite preview --host",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "vercel:deploy": "pnpm dlx vercel@latest deploy --yes",
    "vercel:deploy:prod": "pnpm dlx vercel@latest deploy --prod --yes"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "clsx": "^2.1.1",
    "express": "^4.22.2",
    "lucide-react": "^0.453.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "wouter": "^3.10.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.2",
    "@types/express": "4.17.21",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "esbuild": "^0.25.12",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.6.3",
    "vite": "^7.3.6"
  },
  "packageManager": "pnpm@10.4.1+sha512.c753b6c3ad7afa13af388fa6d808035a008e30ea9993f58c6663e2bc5ff21679aa834db094987129aa4d488b86df57f7b634981b2f827cdcacc698cc0cfb88af",
  "pnpm": {
    "overrides": {
      "qs": "6.15.2",
      "express>path-to-regexp": "0.1.13"
    }
  }
}
